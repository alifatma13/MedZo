---
import "../styles/typography.css";
import "@fontsource-variable/inter";
import "@fontsource-variable/plus-jakarta-sans";
import "@fontsource/podkova/400.css";
import "@fontsource/podkova/700.css";
import Nav from "../components/layout/Nav.astro";
import Footer from "../components/layout/Footer.astro";

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
}

const {
	title = "MedZo - Medical Practice Management for Australian Clinics",
	description = "MedZo provides end-to-end medical practice management across Australia. Billing, scheduling and operations — so you can focus on care.",
	ogImage = "/og-image.png",
} = Astro.props;

const canonicalURL = Astro.url;
const ogImageAbsolute = new URL(ogImage, Astro.site ?? Astro.url.origin).href;

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "MedicalBusiness",
	name: "MedZo",
	description: "End-to-end medical practice management across Australia.",
	url: Astro.url.origin,
	areaServed: {
		"@type": "Country",
		name: "Australia",
	},
	serviceType: [
		"Medical Practice Management",
		"Healthcare Billing",
		"Medicare Compliance",
		"Allied Health Administration",
		"Telehealth Support",
	],
	knowsAbout: [
		"General Practice",
		"Medical Specialists",
		"Allied Health",
		"Dental",
		"Physiotherapy",
		"Telehealth",
		"Multidisciplinary Clinics",
	],
};
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />

		<!-- Canonical (update once domain is known) -->
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageAbsolute} />
		<meta property="og:image:width" content="1080" />
		<meta property="og:image:height" content="1080" />
		<meta property="og:locale" content="en_AU" />
		<meta property="og:site_name" content="MedZo" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageAbsolute} />

		<!-- JSON-LD structured data -->
		<script
			is:inline
			type="application/ld+json"
			set:html={JSON.stringify(jsonLd)}
		/>
	</head>
	<body>
		<Nav />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>

<script>
	import { animate } from "motion";
	if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
		animate("main", { opacity: [0, 1] }, { duration: 0.35 });
	}
</script>
