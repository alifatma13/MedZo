---
// contact.astro — contact page: enquiry form, team members, and office locations.
import Layout from "../layouts/Layout.astro";
import ContactIntroSection from "../components/sections/ContactIntroSection.astro";
import OfficesSection from "../components/sections/OfficesSection.astro";
import { contact } from "../lib/content/contact";
---

<Layout title={contact.meta.title} description={contact.meta.description}>
	<ContactIntroSection hero={contact.hero} form={contact.form} />
	<OfficesSection
		heading={contact.offices.heading}
		body={contact.offices.body}
		locations={contact.offices.locations}
		comingSoon={contact.offices.comingSoon}
	/>
</Layout>
