---
import Layout from "../layouts/Layout.astro";
import { privacy } from "../lib/content/privacy";
---

<Layout title={privacy.metaTitle} description={privacy.metaDescription}>
	<section class="policy">
		<div class="container">
			<p class="updated">Last updated: {privacy.lastUpdated}</p>
			<h1 class="page-title">{privacy.title}</h1>
			<p class="intro">{privacy.intro}</p>

			{
				privacy.sections.map((s) => (
					<div class="section">
						<h2 class="section-heading">{s.heading}</h2>
						<p class="section-body">{s.body}</p>
					</div>
				))
			}

			<a href={privacy.backLink.href} class="back-link"
				>{privacy.backLink.label}</a
			>
		</div>
	</section>
</Layout>

<style>
	.policy {
		padding: 5rem 1.5rem 6rem;
		background: #fff;
	}
	.container {
		max-width: 720px;
		margin: 0 auto;
	}
	.updated {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		margin: 0 0 0.5rem;
	}
	.page-title {
		font-size: var(--text-4xl);
		font-weight: var(--weight-bold);
		color: var(--color-text-heading);
		margin: 0 0 1.5rem;
		line-height: var(--leading-tight);
	}
	.intro {
		font-size: var(--text-base);
		color: var(--color-text-body);
		line-height: var(--leading-relaxed);
		margin: 0 0 3rem;
		border-bottom: 1px solid var(--color-border);
		padding-bottom: 2rem;
	}
	.section {
		margin-bottom: 2.5rem;
	}
	.section-heading {
		font-size: var(--text-xl);
		font-weight: var(--weight-semibold);
		color: var(--color-text-heading);
		margin: 0 0 0.75rem;
	}
	.section-body {
		font-size: var(--text-base);
		color: var(--color-text-body);
		line-height: var(--leading-relaxed);
		margin: 0;
	}
	.back-link {
		display: inline-block;
		margin-top: 2rem;
		font-size: var(--text-sm);
		color: var(--color-primary);
		text-decoration: none;
		font-weight: var(--weight-medium);
	}
	.back-link:hover {
		text-decoration: underline;
	}
	.back-link:focus-visible {
		outline: 2px solid var(--color-primary);
		border-radius: 2px;
	}
</style>
