---
import { Image } from "astro:assets";
import logoImg from "../../res/logo.png";
import { navLinks, navCta, navBrand } from "../../lib/content/nav";
import { icons } from "../../lib/utils/icons";
---

<header class="nav-header">
	<nav class="nav-inner" aria-label="Primary">
		<a href="/" class="nav-logo">
			<Image
				src={logoImg}
				alt={navBrand.logoAlt}
				class="logo-icon"
				width={44}
				height={44}
				format="png"
				quality="max"
				densities={[1, 2]}
				loading="eager"
			/>
			<span class="logo-text">
				<span class="wordmark">{navBrand.wordmark}</span>
				<span class="tagline">{navBrand.tagline}</span>
			</span>
		</a>
		<ul class="nav-links">
			{
				navLinks.map((link) => (
					<li>
						<a href={link.href} class="nav-link">
							{link.label}
						</a>
					</li>
				))
			}
		</ul>
		<a href={navCta.href} class="nav-cta">{navCta.label}</a>
		<button
			class="hamburger"
			id="hamburger-btn"
			aria-label={navBrand.ariaOpenMenu}
			aria-expanded="false"
			aria-controls="mobile-drawer"
		>
			<span class="bar"></span>
			<span class="bar"></span>
			<span class="bar"></span>
		</button>
	</nav>
</header>

<!-- Backdrop -->
<div class="drawer-backdrop" id="drawer-backdrop" aria-hidden="true"></div>

<!-- Left-side mobile drawer -->
<aside
	class="mobile-drawer"
	id="mobile-drawer"
	role="dialog"
	aria-modal="true"
	aria-label={navBrand.ariaDialog}
	aria-hidden="true"
>
	<div class="drawer-top">
		<a href="/" class="drawer-logo">
			<Image
				src={logoImg}
				alt={navBrand.logoAlt}
				width={36}
				height={36}
				format="png"
				quality="max"
			/>
			<span class="drawer-wordmark">{navBrand.wordmark}</span>
		</a>
		<button
			class="close-btn"
			id="drawer-close-btn"
			aria-label={navBrand.ariaCloseMenu}
		>
			<Fragment set:html={icons["nav-close"]} />
		</button>
	</div>

	<nav class="drawer-nav" aria-label="Mobile navigation">
		<ul class="drawer-links">
			{
				navLinks.map((link) => (
					<li>
						<a href={link.href} class="drawer-link">
							{link.label}
						</a>
					</li>
				))
			}
		</ul>
	</nav>

	<div class="drawer-footer">
		<a href={navCta.href} class="drawer-cta">{navCta.label}</a>
		<p class="drawer-tagline">{navBrand.drawerTagline}</p>
	</div>
</aside>

<style>
	/* ── Desktop nav ─────────────────────────────────────── */
	.nav-header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: var(--color-bg-hero);
		box-shadow: none;
		padding-top: 0.75rem;
		transition: box-shadow 0.25s ease;
	}
	.nav-header.scrolled {
		box-shadow: 0 1px 12px rgba(0, 0, 0, 0.08);
	}
	.nav-inner {
		max-width: 1280px;
		margin: 0 auto;
		padding: 0 2rem;
		height: 64px;
		display: flex;
		align-items: center;
		gap: 2rem;
		font-family: var(--font-nav);
	}
	.nav-logo {
		font-size: var(--text-xl);
		font-weight: var(--weight-bold);
		color: var(--color-primary);
		text-decoration: none;
		margin-right: auto;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		letter-spacing: 0.02em;
	}
	.logo-text {
		display: flex;
		flex-direction: column;
		gap: 0;
		line-height: 1;
	}
	.wordmark {
		font-family: var(--font-wordmark);
		font-size: 2.1rem;
		font-weight: var(--weight-regular);
		letter-spacing: 0.02em;
		background: linear-gradient(
			90deg,
			var(--color-accent) 0%,
			var(--color-primary) 100%
		);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
	.tagline {
		font-family: var(--font-wordmark);
		font-size: 0.65rem;
		font-weight: var(--weight-regular);
		color: var(--color-primary);
		letter-spacing: 0.08em;
	}
	.logo-icon {
		height: 44px;
		width: auto;
		display: block;
	}
	.nav-links {
		display: flex;
		list-style: none;
		margin: 0;
		padding: 0;
		gap: 2rem;
	}
	.nav-link {
		font-size: var(--text-base);
		font-weight: var(--weight-medium);
		color: var(--color-text-heading);
		text-decoration: none;
		position: relative;
		transition: color 0.15s;
	}
	.nav-link::after {
		content: "";
		position: absolute;
		bottom: -3px;
		left: 0;
		width: 100%;
		height: 2px;
		border-radius: 999px;
		background: var(--color-accent);
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
	}
	.nav-link:hover {
		color: var(--color-primary);
	}
	.nav-link:hover::after {
		transform: scaleX(1);
	}
	.nav-link:focus-visible {
		outline: 2px solid var(--color-accent);
		border-radius: 2px;
	}
	.nav-cta {
		background: linear-gradient(
			90deg,
			var(--color-accent) 0%,
			var(--color-primary) 100%
		);
		color: #fff;
		padding: 0.5rem 1.25rem;
		border-radius: 0.5rem;
		font-size: var(--text-sm);
		font-weight: var(--weight-semibold);
		text-decoration: none;
		transition: transform 0.15s;
	}
	.nav-cta:hover {
		transform: scale(1.04);
	}
	.nav-cta:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 3px;
	}

	/* ── Hamburger button ────────────────────────────────── */
	.hamburger {
		display: none;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		gap: 5px;
		width: 40px;
		height: 40px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.35rem;
		border-radius: 0.375rem;
		flex-shrink: 0;
	}
	.hamburger:focus-visible {
		outline: 2px solid var(--color-accent);
	}
	.bar {
		display: block;
		width: 22px;
		height: 2px;
		background: var(--color-text-heading);
		border-radius: 999px;
		transition:
			transform 0.28s cubic-bezier(0.22, 1, 0.36, 1),
			opacity 0.2s;
		transform-origin: center;
	}
	.hamburger.is-open .bar:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}
	.hamburger.is-open .bar:nth-child(2) {
		opacity: 0;
		transform: scaleX(0);
	}
	.hamburger.is-open .bar:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	/* ── Backdrop ────────────────────────────────────────── */
	.drawer-backdrop {
		position: fixed;
		inset: 0;
		background: rgba(11, 28, 48, 0.45);
		backdrop-filter: blur(3px);
		z-index: 200;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.3s ease;
	}
	.drawer-backdrop.is-open {
		opacity: 1;
		pointer-events: auto;
	}

	/* ── Mobile drawer ───────────────────────────────────── */
	.mobile-drawer {
		position: fixed;
		top: 0;
		left: 0;
		height: 100%;
		width: 300px;
		max-width: 88vw;
		background: var(--color-bg-hero);
		border-right: 1px solid rgba(0, 50, 125, 0.08);
		box-shadow: 4px 0 32px rgba(0, 50, 125, 0.12);
		z-index: 300;
		display: flex;
		flex-direction: column;
		padding: 1.5rem;
		gap: 0;
		font-family: var(--font-nav);
		transform: translateX(-100%);
		visibility: hidden;
		transition:
			transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
			visibility 0s 0.35s;
	}
	.mobile-drawer.is-open {
		transform: translateX(0);
		visibility: visible;
		transition:
			transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
			visibility 0s 0s;
	}

	/* Drawer top: logo + close */
	.drawer-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid rgba(0, 50, 125, 0.08);
		margin-bottom: 1.5rem;
	}
	.drawer-logo {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
	}
	.drawer-wordmark {
		font-family: var(--font-wordmark);
		font-size: 1.6rem;
		background: linear-gradient(
			90deg,
			var(--color-accent) 0%,
			var(--color-primary) 100%
		);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		font-weight: var(--weight-regular);
	}
	.close-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		background: none;
		border: 1px solid rgba(0, 50, 125, 0.12);
		border-radius: 0.375rem;
		cursor: pointer;
		color: var(--color-text-heading);
		transition:
			background 0.15s,
			border-color 0.15s;
		flex-shrink: 0;
	}
	.close-btn:hover {
		background: rgba(0, 50, 125, 0.06);
		border-color: rgba(0, 50, 125, 0.2);
	}
	.close-btn:focus-visible {
		outline: 2px solid var(--color-accent);
	}

	/* Drawer nav links */
	.drawer-nav {
		flex: 1;
	}
	.drawer-links {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}
	.drawer-link {
		display: flex;
		align-items: center;
		padding: 0.875rem 0.75rem;
		font-size: 1.05rem;
		font-weight: var(--weight-medium);
		color: var(--color-text-heading);
		text-decoration: none;
		border-radius: 0.5rem;
		transition:
			color 0.15s,
			background 0.15s;
	}
	.drawer-link:hover {
		color: var(--color-primary);
		background: rgba(0, 50, 125, 0.05);
	}
	.drawer-link:focus-visible {
		outline: 2px solid var(--color-accent);
	}

	/* Drawer footer: CTA + tagline */
	.drawer-footer {
		padding-top: 1.5rem;
		border-top: 1px solid rgba(0, 50, 125, 0.08);
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-top: auto;
	}
	.drawer-cta {
		display: block;
		text-align: center;
		background: linear-gradient(
			90deg,
			var(--color-accent) 0%,
			var(--color-primary) 100%
		);
		color: #fff;
		padding: 0.875rem 1.5rem;
		border-radius: 0.5rem;
		font-size: var(--text-base);
		font-weight: var(--weight-semibold);
		text-decoration: none;
		transition: transform 0.15s;
	}
	.drawer-cta:hover {
		transform: scale(1.02);
	}
	.drawer-cta:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 3px;
	}
	.drawer-tagline {
		font-size: var(--text-sm);
		color: rgba(0, 50, 125, 0.4);
		text-align: center;
		margin: 0;
		letter-spacing: 0.04em;
	}

	/* ── Responsive ──────────────────────────────────────── */
	@media (max-width: 768px) {
		.nav-links {
			display: none;
		}
		.nav-cta {
			display: none;
		}
		.hamburger {
			display: flex;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.mobile-drawer {
			transition: none;
		}
		.drawer-backdrop {
			transition: none;
		}
		.bar {
			transition: none;
		}
	}
</style>

<script>
	const header = document.querySelector(".nav-header");
	const hamburger = document.getElementById("hamburger-btn");
	const backdrop = document.getElementById("drawer-backdrop");
	const drawer = document.getElementById("mobile-drawer");
	const closeBtn = document.getElementById("drawer-close-btn");
	const drawerLinks = drawer?.querySelectorAll(".drawer-link, .drawer-cta");

	// Scroll shadow on desktop nav
	window.addEventListener(
		"scroll",
		() => {
			header?.classList.toggle("scrolled", window.scrollY > 10);
		},
		{ passive: true },
	);

	function openDrawer() {
		drawer?.classList.add("is-open");
		backdrop?.classList.add("is-open");
		drawer?.removeAttribute("aria-hidden");
		hamburger?.setAttribute("aria-expanded", "true");
		hamburger?.classList.add("is-open");
		document.body.style.overflow = "hidden";
		// Focus first interactive element inside drawer
		setTimeout(() => {
			(drawer?.querySelector(".drawer-link") as HTMLElement | null)?.focus();
		}, 50);
	}

	function closeDrawer() {
		drawer?.classList.remove("is-open");
		backdrop?.classList.remove("is-open");
		drawer?.setAttribute("aria-hidden", "true");
		hamburger?.setAttribute("aria-expanded", "false");
		hamburger?.classList.remove("is-open");
		document.body.style.overflow = "";
		hamburger?.focus();
	}

	hamburger?.addEventListener("click", () => {
		drawer?.classList.contains("is-open") ? closeDrawer() : openDrawer();
	});

	closeBtn?.addEventListener("click", closeDrawer);
	backdrop?.addEventListener("click", closeDrawer);

	drawerLinks?.forEach((link) => {
		link.addEventListener("click", closeDrawer);
	});

	document.addEventListener("keydown", (e) => {
		if (!drawer?.classList.contains("is-open")) return;
		if (e.key === "Escape") {
			closeDrawer();
			return;
		}
		if (e.key !== "Tab") return;

		const focusable = Array.from(
			drawer.querySelectorAll<HTMLElement>("a[href], button:not([disabled])"),
		);
		if (!focusable.length) return;
		const first = focusable[0];
		const last = focusable[focusable.length - 1];

		if (e.shiftKey) {
			if (document.activeElement === first) {
				e.preventDefault();
				last.focus();
			}
		} else {
			if (document.activeElement === last) {
				e.preventDefault();
				first.focus();
			}
		}
	});
</script>
