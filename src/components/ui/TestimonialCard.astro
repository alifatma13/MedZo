---
import type { TestimonialCard } from "../../types/TestimonialCard";
interface Props extends TestimonialCard {}
const { quote, name, role } = Astro.props;
const initials = name
  .split(" ")
  .filter((w) => w !== "Dr." && w !== "Mr." && w !== "Ms." && w !== "Mrs.")
  .map((w) => w[0].toUpperCase())
  .slice(0, 2)
  .join("");
---

<div class="card">
  <p class="quote">"{quote}"</p>
  <div class="author">
    <div class="avatar" aria-hidden="true">{initials}</div>
    <div class="meta">
      <span class="name">{name}</span>
      <span class="role">{role}</span>
    </div>
  </div>
</div>

<style>
  .card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow: 0 1px 1px rgba(0,0,0,.05);
    position: relative;
    overflow: hidden;
    transition:
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.35s ease;
  }
  .card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 35%,
      rgba(255, 255, 255, 0.55) 50%,
      transparent 65%
    );
    transform: translateX(-100%);
    transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
  }
  .card:hover {
    transform: translateY(-6px);
    border-color: var(--color-accent);
    box-shadow:
      0 20px 40px rgba(0, 193, 253, 0.12),
      0 8px 16px rgba(0, 50, 125, 0.08);
  }
  .card:hover::after {
    transform: translateX(100%);
  }
  @media (prefers-reduced-motion: reduce) {
    .card, .card::after { transition: none; }
  }
  .quote {
    font-style: italic;
    color: var(--color-text-body);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    margin: 0 0 1.5rem;
  }
  .author {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .avatar {
    width: 48px;
    height: 48px;
    border-radius: 9999px;
    background: linear-gradient(135deg, var(--color-accent), var(--color-primary));
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 0.75rem;
    font-weight: var(--weight-bold);
    letter-spacing: 0.04em;
  }
  .meta {
    display: flex;
    flex-direction: column;
  }
  .name {
    font-size: var(--text-base);
    color: var(--color-primary);
    line-height: 1.5;
  }
  .role {
    font-size: var(--text-base);
    color: var(--color-text-body);
    line-height: 1.5;
  }
</style>
