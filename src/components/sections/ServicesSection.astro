---
import ServiceCard from "../ui/ServiceCard.astro";
import type { ServiceCard as ServiceCardType } from "../../types/ServiceCard";
import type { SectionHeading } from "../../types/SectionHeading";
interface Props {
  heading: SectionHeading;
  services: ServiceCardType[];
}
const { heading, services } = Astro.props;
---

<section class="services" id="services">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">{heading.title}</h2>
      <p class="section-body">{heading.body}</p>
    </div>
    <div class="grid">
      {services.map((s) => <ServiceCard {...s} />)}
    </div>
  </div>
</section>

<style>
  .services { background: #fff; padding: 6rem 1.5rem; }
  .container { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: flex; flex-direction: column; gap: 4rem; }
  .section-header { display: flex; flex-direction: column; align-items: center; gap: 1rem; text-align: center; }
  .section-title { font-size: var(--text-4xl); font-weight: var(--weight-semibold); color: var(--color-primary); letter-spacing: var(--tracking-tight); margin: 0; }
  .section-body { font-size: var(--text-base); color: var(--color-text-body); margin: 0; max-width: 42rem; }
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  @media (max-width: 1024px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .grid { grid-template-columns: 1fr; } }
</style>

<script>
  import { animate, inView, stagger } from "motion";
  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    inView(".services", () => {
      (animate as any)(".services .section-title", { clipPath: ["inset(0 0 100% 0)", "inset(0 0 0% 0)"], y: [20, 0] }, { duration: 0.65, easing: [0.22, 1, 0.36, 1] });
      (animate as any)(".services .card", { opacity: [0, 1], y: [32, 0] }, { duration: 0.5, delay: stagger(0.08), easing: [0.22, 1, 0.36, 1] });
    });
  }
</script>
