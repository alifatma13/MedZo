---
import type { TickerContent } from "../../types/TickerContent";
interface Props extends TickerContent {}
const { intro, specialties } = Astro.props;
---

<section class="ticker" aria-label="Specialties we support">
  <canvas class="dot-wave" aria-hidden="true"></canvas>

  <div class="container">
    <p class="ticker-text">
      <span>{intro}</span>
      {" "}
      <strong class="highlight">{specialties}</strong>
    </p>
  </div>
</section>

<script>
  import { animate, inView } from "motion";

  // ── Entrance animation ───────────────────────────
  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    inView(".ticker", () => {
      const text = document.querySelector(".ticker .ticker-text");
      // @ts-ignore
      if (text) animate(text, { opacity: [0, 1], y: [24, 0] }, { duration: 0.6, easing: [0.22, 1, 0.36, 1] });
    });
  }

  // ── Dot wave ─────────────────────────────────────
  const canvas = document.querySelector<HTMLCanvasElement>(".ticker .dot-wave");
  const ctx    = canvas?.getContext("2d");

  if (canvas && ctx && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {

    let w = 0, h = 0;

    function resize() {
      const dpr  = window.devicePixelRatio || 1;
      const rect = canvas!.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      canvas!.width  = w * dpr;
      canvas!.height = h * dpr;
      ctx!.scale(dpr, dpr);
    }
    resize();
    window.addEventListener("resize", resize, { passive: true });

    // Two wave bands — navy back, cyan front
    const bands = [
      {
        cy: 0.50,   // center Y as fraction of height
        amp: 0.20,  // amplitude as fraction of height
        cycles: 2,
        phase: 0,
        speed: 0.38,
        rows: 11,
        rowGap: 7,
        dotGap: 13,
        dotR: 2.6,
        rgb: "0,60,160",
      },
      {
        cy: 0.55,
        amp: 0.15,
        cycles: 2,
        phase: Math.PI * 0.55,
        speed: 0.52,
        rows: 9,
        rowGap: 6,
        dotGap: 15,
        dotR: 2.1,
        rgb: "0,60,160",
      },
    ];

    let start: number | null = null;

    function draw(ts: number) {
      if (!start) start = ts;
      const t = (ts - start) / 1000;

      ctx!.clearRect(0, 0, w, h);

      for (const band of bands) {
        const baseY    = h * band.cy;
        const amp      = h * band.amp;
        const halfRows = (band.rows - 1) / 2;

        for (let row = 0; row < band.rows; row++) {
          // Bell-curve opacity: full at centre row, fades to ~8% at edges
          const dist    = Math.abs(row - halfRows) / halfRows;
          const opacity = (1 - dist * dist) * 0.72 + 0.08;
          const radius  = band.dotR * (0.55 + (1 - dist) * 0.45);
          const rowY    = baseY + (row - halfRows) * band.rowGap;
          // Slight phase stagger per row → diagonal flow inside band
          const rowPhase = band.phase + row * 0.18;

          for (let x = 0; x <= w + band.dotGap; x += band.dotGap) {
            const y = rowY + amp * Math.sin(
              (x / w) * band.cycles * Math.PI * 2 + rowPhase + t * band.speed
            );
            ctx!.beginPath();
            ctx!.arc(x, y, radius, 0, Math.PI * 2);
            ctx!.fillStyle = `rgba(${band.rgb},${opacity.toFixed(3)})`;
            ctx!.fill();
          }
        }
      }

      requestAnimationFrame(draw);
    }

    requestAnimationFrame(draw);
  }
</script>

<style>
  .ticker {
    background: linear-gradient(180deg, #f4f8ff 0%, #deeaff 100%);
    padding: 4rem 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .dot-wave {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    mask-image: radial-gradient(ellipse 80% 100% at 50% 50%,
      transparent 44%,
      rgba(0,0,0,0.6) 58%,
      black 72%
    );
    -webkit-mask-image: radial-gradient(ellipse 80% 100% at 50% 50%,
      transparent 44%,
      rgba(0,0,0,0.6) 58%,
      black 72%
    );
  }

  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 2;
  }
  .ticker-text {
    font-family: var(--font-wordmark);
    font-size: var(--text-lg, 1.125rem);
    color: var(--color-text-body);
    text-align: center;
    line-height: 1.7;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .highlight {
    color: var(--color-primary);
    font-weight: var(--weight-bold);
  }
</style>
