---
import { Image } from "astro:assets";
import Button from "../ui/Button.astro";
import heroImage from "../../res/hero_image.png";
import type { HeroContent } from "../../types/HeroContent";
import { icons } from "../../lib/utils/icons";
interface Props extends HeroContent {}
const { heading, subheading, body, ctaPrimary, ctaSecondary, visual } =
	Astro.props;
const headingWords = heading.split(" ");
---

<noscript>
	<style>
		.hero .word-inner,
		.hero .body-first,
		.hero .body-second,
		.hero .cta-row,
		.hero .visual-col {
			opacity: 1 !important;
		}
	</style>
</noscript>

<section class="hero" id="hero">
	<div class="container">
		<div class="text-col">
			<h1 class="heading">
				{
					headingWords.map((word) => (
						<span class="word-mask">
							<span class="word-inner">{word}</span>
						</span>
					))
				}
			</h1>
			<p class="body-first">{subheading}</p>
			<p class="body-second">{body}</p>
			<div class="cta-row">
				<Button
					label={ctaPrimary.label}
					href={ctaPrimary.href}
					variant="primary"
				/>
				<Button
					label={ctaSecondary.label}
					href={ctaSecondary.href}
					variant="outline"
				/>
			</div>
		</div>
		<div class="visual-col" aria-hidden="true">
			<div class="hero-visual">
				<Image
					src={heroImage}
					alt=""
					class="visual-bg"
					widths={[560, 720, 960, 1120]}
					sizes="(max-width: 768px) 100vw, 560px"
					format="webp"
					quality={82}
					loading="eager"
					fetchpriority="high"
				/>
				<div class="visual-tint"></div>

				<div class="metric-card metric-card--appointments">
					<div class="metric-top">
						<strong>{visual.appointments.count}</strong>
						<span>{visual.appointments.change}</span>
					</div>
					<p>{visual.appointments.label}</p>
					<small>{visual.appointments.period}</small>
				</div>

				<div class="action-grid">
					{
						visual.actionCards.map((card) => (
							<div class="action-card">
								<Fragment set:html={icons[card.icon]} />
								<span>{card.label}</span>
							</div>
						))
					}
				</div>

				<div class="insight-pill">
					<span></span>
					{visual.insightPill}
				</div>

				<div class="revenue-card">
					<div class="revenue-head">
						<strong>{visual.revenue.title}</strong>
						<span>{visual.revenue.period}</span>
					</div>
					<div class="chart" aria-hidden="true">
						{
							visual.revenue.bars.map((bar) => (
								<i
									class={bar.active ? "active" : undefined}
									style={`--bar-height: ${bar.height}`}
								/>
							))
						}
					</div>
					<div class="months">
						{visual.revenue.months.map((month) => <span>{month}</span>)}
					</div>
				</div>

				<div class="profile-card">
					<span class="avatar">{visual.profile.initials}</span>
					<div>
						<strong>{visual.profile.name}</strong>
						<small>{visual.profile.role}</small>
					</div>
					<span class="rating">{visual.profile.rating}</span>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		background: var(--color-bg-hero);
		padding: 5.5rem 1.5rem 6rem;
		overflow: visible;
	}
	.container {
		max-width: 1280px;
		margin: 0 auto;
		padding: 0 2rem;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
		align-items: center;
	}
	.text-col {
		display: flex;
		flex-direction: column;
	}
	.heading {
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: var(--weight-bold);
		color: var(--color-primary);
		letter-spacing: var(--tracking-tight);
		line-height: 1.2;
		margin: 0 0 1.5rem;
	}
	.word-mask {
		display: inline-block;
		overflow: hidden;
		vertical-align: bottom;
		margin-right: 0.28em;
		line-height: 1.25;
	}
	.word-mask:last-child {
		margin-right: 0;
	}
	.word-inner {
		display: inline-block;
	}
	.body-first {
		color: var(--color-text-body);
		margin: 0 0 1.5rem;
		max-width: 32rem;
	}
	.body-second {
		color: var(--color-text-heading);
		margin: 0 0 3.5rem;
		max-width: 32rem;
	}
	.cta-row {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.visual-col {
		position: relative;
		min-width: 0;
		padding: 2rem 1.35rem 2.35rem 2.2rem;
	}
	.hero-visual {
		position: relative;
		width: min(100%, 35rem);
		aspect-ratio: 1.08 / 1;
		margin-left: auto;
		border-radius: 8px;
		background: #eef6ff;
		box-shadow: 0 28px 60px rgba(0, 50, 125, 0.14);
		overflow: visible;
	}
	.visual-bg,
	.visual-tint {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
	}
	.visual-bg {
		object-fit: cover;
		object-position: 54% center;
		display: block;
		border-radius: 8px;
	}
	.visual-tint {
		border-radius: 8px;
		background:
			linear-gradient(
				90deg,
				rgba(248, 249, 255, 0.32) 0%,
				rgba(248, 249, 255, 0.04) 50%,
				rgba(0, 50, 125, 0.08) 100%
			),
			linear-gradient(
				180deg,
				rgba(11, 28, 48, 0.02) 0%,
				rgba(11, 28, 48, 0.18) 100%
			);
	}
	.metric-card,
	.action-card,
	.revenue-card,
	.profile-card,
	.insight-pill {
		position: absolute;
		--float-x: 0.25rem;
		--float-y: -0.45rem;
		--float-rotate: 0.35deg;
		--float-duration: 8s;
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.94);
		box-shadow: 0 1rem 2.4rem rgba(0, 50, 125, 0.12);
		font-family: var(--font-nav);
		animation: hero-card-float var(--float-duration) ease-in-out infinite;
		animation-delay: var(--float-delay, 0s);
		will-change: transform;
	}
	.metric-card {
		--float-x: 0.28rem;
		--float-y: -0.55rem;
		--float-rotate: -0.45deg;
		--float-duration: 7.8s;
		--float-delay: -1.2s;
		left: -6%;
		top: 8%;
		width: 7.8rem;
		padding: 0.95rem 1rem;
		background: #ebff53;
		color: #0b1c30;
	}
	.metric-top {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}
	.metric-top strong {
		font-size: 2rem;
		line-height: 1;
	}
	.metric-top span {
		padding: 0.22rem 0.42rem;
		border-radius: 999px;
		background: #fff;
		font-size: 0.68rem;
		font-weight: var(--weight-bold);
	}
	.metric-card p,
	.metric-card small {
		display: block;
		margin: 0;
		font-size: 0.66rem;
		line-height: 1.35;
	}
	.metric-card p {
		margin-top: 0.65rem;
		font-weight: var(--weight-bold);
	}
	.action-grid {
		position: absolute;
		inset: 0;
		width: auto;
	}
	.action-card {
		position: absolute;
		width: 5.4rem;
		height: 4.6rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.45rem;
		color: #0b1c30;
	}
	.action-card:nth-child(1) {
		--float-x: 0.28rem;
		--float-y: -0.55rem;
		--float-rotate: -0.45deg;
		--float-duration: 7.8s;
		--float-delay: -1.2s;
		top: calc(10% - 4.6rem);
		left: calc(-6% + 7.8rem);
		right: auto;
	}
	.action-card:nth-child(2) {
		--float-x: -0.22rem;
		--float-y: -0.5rem;
		--float-rotate: -0.35deg;
		--float-duration: 9.2s;
		--float-delay: -2.5s;
		top: 10%;
		left: auto;
		right: -8%;
	}
	.action-card:nth-child(3) {
		--float-x: 0.24rem;
		--float-y: 0.42rem;
		--float-rotate: -0.3deg;
		--float-duration: 8.8s;
		--float-delay: -1.7s;
		top: 30%;
		left: auto;
		right: -8%;
	}
	.action-card:nth-child(4) {
		--float-x: -0.18rem;
		--float-y: 0.48rem;
		--float-rotate: 0.35deg;
		--float-duration: 9.6s;
		--float-delay: -3.1s;
		top: 52%;
		left: auto;
		right: -8%;
	}
	.action-card svg {
		width: 1.25rem;
		height: 1.25rem;
		fill: none;
		stroke: currentColor;
		stroke-width: 1.8;
		stroke-linecap: round;
		stroke-linejoin: round;
	}
	.action-card span {
		font-size: 0.68rem;
		font-weight: var(--weight-semibold);
	}
	.insight-pill {
		--float-x: 0.2rem;
		--float-y: -0.34rem;
		--float-rotate: 0.2deg;
		--float-duration: 7.2s;
		--float-delay: -0.9s;
		left: -1%;
		top: calc(58% - 50px);
		display: flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.5rem 0.75rem;
		color: #fff;
		background: rgba(0, 50, 125, 0.58);
		font-size: 0.72rem;
		backdrop-filter: blur(12px);
	}
	.insight-pill span {
		width: 0.55rem;
		height: 0.55rem;
		border-radius: 50%;
		background: #ebff53;
		box-shadow: 0 0 0 0.28rem rgba(235, 255, 83, 0.2);
	}
	.revenue-card {
		--float-x: -0.32rem;
		--float-y: -0.5rem;
		--float-rotate: 0.28deg;
		--float-duration: 9s;
		--float-delay: -2s;
		left: -3%;
		bottom: 12%;
		width: 12.2rem;
		padding: 0.85rem;
	}
	.revenue-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
	}
	.revenue-head strong {
		font-size: 0.76rem;
	}
	.revenue-head span {
		padding: 0.25rem 0.42rem;
		border-radius: 6px;
		background: #f2f5fb;
		color: var(--color-text-body);
		font-size: 0.58rem;
	}
	.chart {
		height: 3.6rem;
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		align-items: end;
		gap: 0.35rem;
		margin-top: 0.65rem;
	}
	.chart i {
		height: var(--bar-height);
		border-radius: 3px 3px 0 0;
		background: #2f332e;
	}
	.chart i.active {
		background: #ebff53;
	}
	.months {
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		margin-top: 0.35rem;
		color: #8b95a5;
		font-size: 0.55rem;
		text-align: center;
	}
	.profile-card {
		--float-x: 0.3rem;
		--float-y: 0.42rem;
		--float-rotate: -0.25deg;
		--float-duration: 8.2s;
		--float-delay: -1.4s;
		left: auto;
		right: -8%;
		bottom: 5%;
		width: min(20rem, 52%);
		display: flex;
		align-items: center;
		gap: 0.85rem;
		padding: 0.85rem 1rem;
	}
	.avatar {
		width: 2.25rem;
		height: 2.25rem;
		display: grid;
		place-items: center;
		flex: 0 0 auto;
		border-radius: 50%;
		background: linear-gradient(
			135deg,
			var(--color-primary),
			var(--color-accent)
		);
		color: #fff;
		font-size: 0.7rem;
		font-weight: var(--weight-bold);
	}
	.profile-card div {
		min-width: 0;
	}
	.profile-card strong,
	.profile-card small {
		display: block;
		white-space: nowrap;
	}
	.profile-card strong {
		color: #0b1c30;
		font-size: 0.95rem;
	}
	.profile-card small {
		color: var(--color-text-body);
		font-size: 0.68rem;
	}
	.rating {
		margin-left: auto;
		padding: 0.25rem 0.5rem;
		border-radius: 999px;
		background: #f2f5fb;
		color: #0b1c30;
		font-size: 0.66rem;
		font-weight: var(--weight-bold);
	}
	@keyframes hero-card-float {
		0%,
		100% {
			transform: translate3d(0, 0, 0) rotate(0deg);
		}
		50% {
			transform: translate3d(var(--float-x), var(--float-y), 0)
				rotate(var(--float-rotate));
		}
	}
	/* Hide animated elements before JS runs — only when motion is allowed.
     prefers-reduced-motion: reduce skips this so content stays visible. */
	@media (prefers-reduced-motion: no-preference) {
		.word-inner {
			opacity: 0;
		}
		.body-first,
		.body-second {
			opacity: 0;
		}
		.cta-row {
			opacity: 0;
		}
		.visual-col {
			opacity: 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.metric-card,
		.action-card,
		.revenue-card,
		.profile-card,
		.insight-pill {
			animation: none;
			transform: none;
		}
	}
	/* ── iPad landscape (1025px–1280px) — 2-col, pull cards in ── */
	@media (min-width: 1025px) and (max-width: 1280px) {
		.hero-visual {
			width: min(100%, 28rem);
		}
		/* Left-side cards: pull off the bleed */
		.metric-card {
			left: -1%;
		}
		.revenue-card {
			left: -1%;
		}
		/* Right-side action cards: overlap right edge of image */
		.action-card:nth-child(1) {
			left: calc(-1% + 7rem);
		}
		.action-card:nth-child(2) {
			right: -4%;
			top: 8%;
		}
		.action-card:nth-child(3) {
			right: -4%;
			top: 32%;
		}
		.action-card:nth-child(4) {
			right: -4%;
			top: 56%;
		}
		.profile-card {
			right: -4%;
		}
	}
	@media (max-width: 1024px) {
		.hero {
			padding: 3rem 2rem 5rem;
		}
		.container {
			grid-template-columns: 1fr;
			padding: 0 1rem;
			gap: 2.5rem;
		}
		.visual-col {
			order: 2;
			padding: 1.4rem 1rem 2rem;
		}
		.hero-visual {
			margin: 0 auto;
			max-width: 27rem;
		}
	}
	@media (max-width: 480px) {
		.hero-visual {
			aspect-ratio: 1 / 1.08;
		}
		.visual-bg {
			object-position: 58% center;
		}
		.action-card {
			width: 3.8rem;
			height: 3.2rem;
			gap: 0.3rem;
		}
		.action-card svg {
			width: 1rem;
			height: 1rem;
		}
		.action-card span {
			font-size: 0.55rem;
		}
		.action-card:nth-child(1) {
			top: calc(15% - 3.2rem);
			left: calc(-3% + 5.8rem);
			right: auto;
		}
		.action-card:nth-child(2) {
			top: 6%;
			left: auto;
			right: -3%;
		}
		.action-card:nth-child(3) {
			top: 30%;
			left: auto;
			right: -3%;
		}
		.action-card:nth-child(4) {
			top: 54%;
			left: auto;
			right: -3%;
		}
		.metric-card {
			left: -3%;
			top: 15%;
			width: 5.8rem;
			padding: 0.6rem 0.65rem;
		}
		.metric-top strong {
			font-size: 1.35rem;
		}
		.metric-top span {
			font-size: 0.58rem;
		}
		.metric-card p,
		.metric-card small {
			font-size: 0.58rem;
		}
		.insight-pill {
			display: none;
		}
		.revenue-card {
			left: -2%;
			bottom: 8%;
			width: 9.2rem;
			padding: 0.65rem;
		}
		.revenue-head strong {
			font-size: 0.66rem;
		}
		.revenue-head span {
			font-size: 0.52rem;
		}
		.chart {
			height: 2.8rem;
		}
		.months {
			font-size: 0.48rem;
		}
		.profile-card {
			left: 38%;
			right: -3%;
			bottom: -5%;
			width: auto;
			padding: 0.65rem 0.75rem;
			gap: 0.6rem;
		}
		.avatar {
			width: 1.8rem;
			height: 1.8rem;
			font-size: 0.6rem;
		}
		.profile-card strong {
			font-size: 0.8rem;
		}
		.profile-card small {
			font-size: 0.58rem;
		}
		.rating {
			font-size: 0.58rem;
		}
	}
</style>

<script>
	import { animate, stagger } from "motion";

	if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
		// Wait for fonts before animating — prevents system-font → web-font snap mid-animation.
		// Race against 900ms so a slow font CDN never stalls the entrance indefinitely.
		const fontsReady = Promise.race([
			document.fonts.ready,
			new Promise<void>((resolve) => setTimeout(resolve, 900)),
		]);

		fontsReady.then(() => {
			(animate as any)(
				".hero .word-inner",
				{ y: ["105%", "0%"], opacity: [0, 1] },
				{ duration: 0.55, delay: stagger(0.07), easing: [0.22, 1, 0.36, 1] },
			);
			(animate as any)(
				".hero .body-first, .hero .body-second",
				{ opacity: [0, 1], y: [16, 0] },
				{
					duration: 0.5,
					delay: stagger(0.15, { startDelay: 0.45 }),
					easing: "ease-out",
				},
			);
			(animate as any)(
				".hero .cta-row",
				{ opacity: [0, 1], y: [16, 0] },
				{ duration: 0.5, delay: 0.75, easing: "ease-out" },
			);
			(animate as any)(
				".hero .visual-col",
				{ opacity: [0, 1], x: [32, 0] },
				{ duration: 0.7, delay: 0.2, easing: [0.22, 1, 0.36, 1] },
			);
		});
	}
</script>
