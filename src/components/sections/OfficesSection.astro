---
// OfficesSection.astro — contact page section listing physical office locations plus a coming-soon card.
import { icons } from "../../lib/utils/icons";
import type { Office, ComingSoonCard } from "../../types/ContactContent";

interface Props {
	heading: string;
	body: string;
	locations: Office[];
	comingSoon: ComingSoonCard;
}
const { heading, body, locations, comingSoon } = Astro.props;
---

<section class="offices" id="offices">
	<div class="container">
		<div class="section-header">
			<h2 class="section-title">{heading}</h2>
			<p class="section-body">{body}</p>
		</div>
		<div class="grid">
			{
				locations.map((loc) => (
					<div class="office-card">
						<div class="card-top">
							<span class="state-badge">{loc.state}</span>
							<h3 class="suburb">{loc.suburb}</h3>
						</div>
						<ul class="detail-list" aria-label={`${loc.suburb} office details`}>
							<li class="detail-item">
								<span class="detail-icon" aria-hidden="true">
									<Fragment set:html={icons["map-pin"]} />
								</span>
								<address class="address">
									{loc.address.split("\n").map((line) => (
										<span class="address-line">{line}</span>
									))}
								</address>
							</li>
							<li class="detail-item">
								<span class="detail-icon" aria-hidden="true">
									<Fragment set:html={icons["phone"]} />
								</span>
								<a
									href={`tel:${loc.phone.replace(/\s/g, "")}`}
									class="detail-link"
								>
									{loc.phone}
								</a>
							</li>
							<li class="detail-item">
								<span class="detail-icon" aria-hidden="true">
									<Fragment set:html={icons["mail"]} />
								</span>
								<a href={`mailto:${loc.email}`} class="detail-link">
									{loc.email}
								</a>
							</li>
						</ul>
					</div>
				))
			}
			<div class="office-card office-card--coming-soon" aria-label="Coming soon location">
				<div class="card-top">
					<span class="state-badge state-badge--soon">{comingSoon.badge}</span>
				</div>
				<div class="soon-body">
					<span class="soon-icon" aria-hidden="true">
						<Fragment set:html={icons["map-pin"]} />
					</span>
					<h3 class="soon-heading">{comingSoon.heading}</h3>
					<p class="soon-text">{comingSoon.body}</p>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.offices {
		background: #fff;
		padding: 5rem 5rem;
	}
	.container {
		max-width: 1280px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 4rem;
	}
	.section-header {
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.75rem;
	}
	.section-title {
		font-size: var(--text-4xl);
		font-weight: var(--weight-semibold);
		color: var(--color-primary);
		letter-spacing: var(--tracking-tight);
		margin: 0;
	}
	.section-body {
		font-size: var(--text-base);
		color: var(--color-text-body);
		margin: 0;
		max-width: 42rem;
	}
	.grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2rem;
	}
	.office-card {
		border: 1.5px solid var(--color-border);
		border-radius: 1rem;
		padding: 2.5rem;
		display: flex;
		flex-direction: column;
		gap: 1.75rem;
		transition: border-color 0.2s, box-shadow 0.2s;
	}
	.office-card:hover {
		border-color: var(--color-accent);
		box-shadow: 0 4px 20px rgba(0, 193, 253, 0.1);
	}
	.card-top {
		display: flex;
		align-items: center;
		gap: 1rem;
	}
	.state-badge {
		background: linear-gradient(90deg, var(--color-accent) 0%, var(--color-primary) 100%);
		color: #fff;
		font-size: var(--text-xs);
		font-weight: var(--weight-bold);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		padding: 0.3rem 0.75rem;
		border-radius: 2rem;
	}
	.suburb {
		font-size: var(--text-2xl);
		font-weight: var(--weight-semibold);
		color: var(--color-text-heading);
		margin: 0;
	}
	.detail-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.detail-item {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
	}
	.detail-icon {
		width: 1.125rem;
		height: 1.125rem;
		flex-shrink: 0;
		color: var(--color-accent);
		margin-top: 0.1rem;
	}
	.detail-icon :global(svg) {
		width: 100%;
		height: 100%;
	}
	.address {
		font-style: normal;
		display: flex;
		flex-direction: column;
		gap: 0.125rem;
	}
	.address-line {
		font-size: var(--text-sm);
		color: var(--color-text-body);
		display: block;
	}
	.detail-link {
		font-size: var(--text-sm);
		color: var(--color-text-body);
		text-decoration: none;
		transition: color 0.15s;
	}
	.detail-link:hover {
		color: var(--color-accent);
	}
	.detail-link:focus-visible {
		outline: 2px solid var(--color-accent);
		border-radius: 2px;
	}
	.office-card--coming-soon {
		border-style: dashed;
		border-color: var(--color-border);
		background: #fafbff;
		display: flex;
		flex-direction: column;
		gap: 1.75rem;
		justify-content: flex-start;
	}
	.office-card--coming-soon:hover {
		border-color: var(--color-accent);
		box-shadow: 0 4px 20px rgba(0, 193, 253, 0.08);
	}
	.state-badge--soon {
		background: transparent;
		border: 1.5px solid var(--color-accent);
		color: var(--color-accent);
	}
	.soon-body {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.75rem;
	}
	.soon-icon {
		width: 2rem;
		height: 2rem;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		background: rgba(0, 193, 253, 0.1);
		color: var(--color-accent);
		padding: 0.4rem;
	}
	.soon-icon :global(svg) {
		width: 100%;
		height: 100%;
	}
	.soon-heading {
		font-size: var(--text-2xl);
		font-weight: var(--weight-semibold);
		color: var(--color-text-heading);
		margin: 0;
	}
	.soon-text {
		font-size: var(--text-sm);
		color: var(--color-text-body);
		margin: 0;
		line-height: var(--leading-relaxed);
	}
	@media (max-width: 640px) {
		.offices {
			padding: 3.5rem 1.25rem;
		}
		.grid {
			grid-template-columns: 1fr;
		}
		.office-card {
			padding: 1.75rem;
		}
	}
</style>

<script>
	import { animate, inView, stagger } from "motion";
	document.addEventListener("astro:page-load", () => {
		if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
			inView(".offices", () => {
				(animate as any)(
					".offices .section-title, .offices .section-body",
					{ opacity: [0, 1], y: [16, 0] },
					{ duration: 0.5, easing: [0.22, 1, 0.36, 1] },
				);
				(animate as any)(
					".offices .office-card",
					{ opacity: [0, 1], y: [28, 0] },
					{
						duration: 0.5,
						delay: stagger(0.12),
						easing: [0.22, 1, 0.36, 1],
					},
				);
			});
		}
	});
</script>
