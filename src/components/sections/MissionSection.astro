---
// MissionSection.astro — mission statement block with heading and body copy.
interface Props {
	heading: string;
	body: string;
}
const { heading, body } = Astro.props;
---

<section class="mission">
	<div class="container">
		<div class="inner">
			<h2 class="heading">{heading}</h2>
			<div class="divider" aria-hidden="true"></div>
			<p class="body">{body}</p>
		</div>
	</div>
</section>

<style>
	.mission {
		background: var(--color-primary);
		padding: 6rem 5rem;
	}
	.container {
		max-width: 820px;
		margin: 0 auto;
	}
	.inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
	}
	.heading {
		font-size: clamp(1.5rem, 3vw, var(--text-4xl));
		font-weight: var(--weight-bold);
		color: #fff;
		letter-spacing: var(--tracking-tight);
		line-height: var(--leading-tight);
		margin: 0 0 1.5rem;
	}
	.divider {
		width: 3rem;
		height: 3px;
		background: linear-gradient(90deg, var(--color-accent) 0%, rgba(0, 193, 253, 0.3) 100%);
		border-radius: 2px;
		margin-bottom: 1.75rem;
	}
	.body {
		font-size: var(--text-lg);
		color: rgba(255, 255, 255, 0.8);
		line-height: var(--leading-loose);
		margin: 0;
		max-width: 68ch;
	}
	@media (max-width: 900px) {
		.mission {
			padding: 4rem 3rem;
		}
	}
	@media (max-width: 640px) {
		.mission {
			padding: 3.5rem 1.25rem;
		}
	}
</style>

<script>
	import { animate, inView } from "motion";

	document.addEventListener("astro:page-load", () => {
		if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

		inView(".mission .inner", ({ target }) => {
			(animate as any)(
				target,
				{ opacity: [0, 1], y: [24, 0] },
				{ duration: 0.6, easing: [0.22, 1, 0.36, 1] },
			);
		});
	});
</script>
