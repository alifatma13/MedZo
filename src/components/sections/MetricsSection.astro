---
import type { Metric } from "../../types/Metric";
interface Props {
  metrics: Metric[];
}
const { metrics } = Astro.props;
---

<section class="metrics">
  <div class="container">
    {metrics.map((m) => (
      <div class="metric-item">
        <p class="metric-value">
          <span class="count" data-target={m.value} data-suffix={m.suffix}>
            {m.value >= 1000 ? m.value.toLocaleString("en-AU") : m.value}{m.suffix}
          </span>
        </p>
        <p class="metric-label">{m.label}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .metrics {
    background: var(--color-primary);
    padding: 4rem 1.5rem;
  }
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    text-align: center;
  }
  .metric-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 2rem 1rem;
  }
  .metric-item:not(:last-child) {
    border-right: 1px solid rgba(255, 255, 255, 0.12);
  }
  .metric-value {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    font-weight: var(--weight-extrabold);
    color: #fff;
    line-height: 1;
    margin: 0;
    letter-spacing: var(--tracking-tight);
    text-shadow:
      0 0 24px rgba(0, 193, 253, 0.55),
      0 0 60px rgba(0, 193, 253, 0.25);
  }
  .metric-label {
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
    line-height: var(--leading-normal);
  }
  @media (max-width: 640px) {
    .container { grid-template-columns: 1fr; }
    .metric-item { padding: 1.5rem 0; border-right: none; border-bottom: 1px solid rgba(255,255,255,0.12); }
    .metric-item:last-child { border-bottom: none; }
  }
</style>

<script>
  import { inView, animate } from "motion";

  inView(".metrics", () => {
    const items = document.querySelectorAll<HTMLElement>(".metrics .metric-item");
    if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      (animate as any)(items, { opacity: [0, 1], y: [24, 0] }, { duration: 0.5, delay: (i: number) => i * 0.12, easing: [0.22, 1, 0.36, 1] });
    }

    document.querySelectorAll<HTMLElement>(".metrics .count").forEach((el) => {
      const target = parseFloat(el.dataset.target ?? "0");
      const suffix = el.dataset.suffix ?? "";
      const isLarge = target >= 1000;

      const format = (v: number) =>
        isLarge ? Math.round(v).toLocaleString("en-AU") : Math.round(v).toString();

      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        el.textContent = format(target);
        return;
      }

      el.textContent = format(0) + suffix;
      (animate as any)(0, target, {
        duration: isLarge ? 2.2 : 1.4,
        easing: [0.22, 1, 0.36, 1],
        onUpdate: (v: number) => { el.textContent = format(v) + suffix; },
      });
    });
  });
</script>
