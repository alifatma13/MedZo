---
// CredentialsSection.astro — credentials checklist and CTA block.
import { icons } from "../../lib/utils/icons";
interface Props {
	credentialsHeading: string;
	credentialItems: string[];
	ctaBody: string;
	ctaButtonLabel: string;
	ctaButtonHref: string;
}
const {
	credentialsHeading,
	credentialItems,
	ctaBody,
	ctaButtonLabel,
	ctaButtonHref,
} = Astro.props;
---

<section class="credentials">
	<div class="container">
		<!-- Credentials -->
		<div class="creds-block">
			<h2 class="section-heading">{credentialsHeading}</h2>
			<ul class="cred-list" role="list">
				{
					credentialItems.map((item) => (
						<li class="cred-item">
							<span class="check-icon" aria-hidden="true">
								<Fragment set:html={icons["cred-check"]} />
							</span>
							<span>{item}</span>
						</li>
					))
				}
			</ul>
		</div>

		<!-- CTA -->
		<div class="cta-block">
			<p class="cta-body">{ctaBody}</p>
			<a href={ctaButtonHref} class="cta-btn">{ctaButtonLabel}</a>
		</div>
	</div>
</section>

<style>
	.credentials {
		background: var(--color-bg-hero);
		padding: 6rem 5rem;
	}
	.container {
		max-width: 820px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 4rem;
	}
	.section-heading {
		font-size: clamp(1.25rem, 2.5vw, var(--text-3xl));
		font-weight: var(--weight-bold);
		color: var(--color-primary);
		letter-spacing: var(--tracking-tight);
		line-height: var(--leading-tight);
		margin: 0 0 1.75rem;
		text-align: center;
	}

	/* ── Credentials list ────────────────────────────────── */
	.cred-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.cred-item {
		display: flex;
		align-items: flex-start;
		gap: 0.85rem;
		font-size: var(--text-base);
		color: var(--color-text-body);
		line-height: var(--leading-loose);
	}
	.check-icon {
		flex-shrink: 0;
		margin-top: 0.2rem;
	}

	/* ── CTA ─────────────────────────────────────────────── */
	.cta-block {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 2rem;
		padding: 4rem 3rem;
		background: var(--color-primary);
		border-radius: 1.5rem;
		position: relative;
		overflow: hidden;
	}
	.cta-block::before,
	.cta-block::after {
		content: "";
		position: absolute;
		border-radius: 50%;
		pointer-events: none;
	}
	.cta-block::before {
		width: 22rem;
		height: 22rem;
		border: 1px solid rgba(0, 193, 253, 0.15);
		top: -8rem;
		right: -6rem;
	}
	.cta-block::after {
		width: 14rem;
		height: 14rem;
		border: 1.5px solid rgba(0, 193, 253, 0.1);
		top: -4rem;
		right: -2rem;
	}
	.cta-body {
		font-size: var(--text-lg);
		color: rgba(255, 255, 255, 0.8);
		line-height: var(--leading-loose);
		margin: 0;
		max-width: 58ch;
		position: relative;
		z-index: 1;
	}
	.cta-btn {
		display: inline-block;
		background: #fff;
		color: var(--color-primary);
		font-size: var(--text-sm);
		font-family: var(--font-nav);
		font-weight: var(--weight-semibold);
		letter-spacing: 0.02em;
		text-decoration: none;
		padding: 0.85rem 2.25rem;
		border-radius: 0.5rem;
		transition: background 0.2s, color 0.2s;
		position: relative;
		z-index: 1;
	}
	.cta-btn:hover {
		background: var(--color-accent);
		color: #fff;
	}
	.cta-btn:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 3px;
	}

	@media (max-width: 900px) {
		.credentials {
			padding: 4rem 3rem;
		}
		.container {
			gap: 3rem;
		}
	}
	@media (max-width: 640px) {
		.credentials {
			padding: 3.5rem 1.25rem;
		}
		.cta-block {
			padding: 3rem 1.5rem;
		}
	}
</style>

<script>
	import { animate, inView, stagger } from "motion";

	document.addEventListener("astro:page-load", () => {
		if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

		inView(".credentials .creds-block", ({ target: t }) => {
			(animate as any)(
				(t as HTMLElement).querySelectorAll(".cred-item"),
				{ opacity: [0, 1], x: [-16, 0] },
				{ duration: 0.45, delay: stagger(0.06), easing: [0.22, 1, 0.36, 1] },
			);
		});

		inView(".credentials .cta-block", ({ target: t }) => {
			(animate as any)(
				t as HTMLElement,
				{ opacity: [0, 1], y: [20, 0] },
				{ duration: 0.5, easing: [0.22, 1, 0.36, 1] },
			);
		});
	});
</script>
