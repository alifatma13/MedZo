---
// AboutHeroSection.astro — hero for the /about page: page title, h1, and intro paragraphs.
interface Props {
	title: string;
	heading: string;
	paragraphs: string[];
}
const { title, heading, paragraphs } = Astro.props;
---

<section class="about-hero">
	<div class="container">
		{title && <p class="page-label">{title}</p>}
		<h1 class="heading">{heading}</h1>
		<div class="body-text">
			{paragraphs.map((p) => <p>{p}</p>)}
		</div>
	</div>
</section>

<style>
	.about-hero {
		background: var(--color-bg-hero);
		padding: 6rem 5rem 5rem;
		position: relative;
		overflow: hidden;
	}
	.about-hero::before {
		content: "";
		position: absolute;
		right: -8rem;
		top: -6rem;
		width: 48rem;
		height: 48rem;
		border-radius: 50%;
		border: 1px solid rgba(0, 193, 253, 0.08);
		pointer-events: none;
	}
	.about-hero::after {
		content: "";
		position: absolute;
		right: -8rem;
		top: -6rem;
		width: 30rem;
		height: 30rem;
		border-radius: 50%;
		border: 1.5px solid rgba(0, 193, 253, 0.14);
		pointer-events: none;
	}
	.container {
		max-width: 820px;
		margin: 0 auto;
		position: relative;
		z-index: 1;
	}
	.page-label {
		font-size: var(--text-sm);
		font-family: var(--font-nav);
		font-weight: var(--weight-semibold);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-accent);
		margin: 0 0 1rem;
	}
	.heading {
		font-size: clamp(2rem, 4vw, var(--text-5xl));
		font-weight: var(--weight-bold);
		color: var(--color-primary);
		letter-spacing: var(--tracking-tight);
		line-height: var(--leading-tight);
		margin: 0 0 2rem;
		text-align: center;
	}
	.body-text {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}
	.body-text p {
		font-size: var(--text-lg);
		color: var(--color-text-body);
		line-height: var(--leading-loose);
		margin: 0;
		max-width: 72ch;
	}
	@media (max-width: 900px) {
		.about-hero {
			padding: 4rem 3rem 3.5rem;
		}
		.about-hero::before,
		.about-hero::after {
			display: none;
		}
	}
	@media (max-width: 640px) {
		.about-hero {
			padding: 3.5rem 1.25rem 3rem;
		}
		.heading {
			text-align: left;
			font-size: clamp(1.6rem, 6vw, 2rem);
		}
		.body-text p {
			font-size: var(--text-base);
		}
	}
</style>

<script>
	import { animate } from "motion";

	document.addEventListener("astro:page-load", () => {
		if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
		(animate as any)(
			".about-hero .page-label",
			{ opacity: [0, 1], y: [10, 0] },
			{ duration: 0.4, easing: [0.22, 1, 0.36, 1] },
		);
		(animate as any)(
			".about-hero .heading",
			{ opacity: [0, 1], y: [20, 0] },
			{ duration: 0.5, delay: 0.1, easing: [0.22, 1, 0.36, 1] },
		);
		(animate as any)(
			".about-hero .body-text",
			{ opacity: [0, 1], y: [16, 0] },
			{ duration: 0.5, delay: 0.2, easing: [0.22, 1, 0.36, 1] },
		);
	});
</script>
