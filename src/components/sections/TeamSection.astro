---
// TeamSection.astro — team member carousel used on the /about page.
import type { TeamMember } from "../../types/AboutContent";
import { icons } from "../../lib/utils/icons";

interface Props {
	heading: string;
	body: string;
	members: TeamMember[];
}
const { heading, body, members } = Astro.props;

function initials(name: string): string {
	const parts = name.trim().split(/\s+/);
	return (parts[0][0] + (parts[parts.length - 1][0] ?? "")).toUpperCase();
}
---

<section class="team" id="team">
	<div class="container">
		<div class="section-header">
			<h2 class="section-title">{heading}</h2>
			<p class="section-body">{body}</p>
		</div>
		<div class="carousel-wrap">
			<button class="arrow arrow-prev" aria-label="Scroll left">
				<Fragment set:html={icons["carousel-prev"]} />
			</button>
			<div class="track">
				{
					members.map((member) => (
						<article class="card">
							<div class="photo-wrap">
								{member.imageUrl ? (
									<img
										src={member.imageUrl}
										alt={`Photo of ${member.name}`}
										class="photo"
										loading="lazy"
										style={`object-position: ${member.imagePosition ?? "center 20%"}`}
									/>
								) : (
									<div class="initials" aria-hidden="true">{initials(member.name)}</div>
								)}
							</div>
							<div class="card-body">
								<p class="member-role">{member.role}</p>
								<h3 class="member-name">{member.name}</h3>
								<p class="member-bio">{member.bio}</p>
							<button class="read-more" aria-expanded="false">Read more</button>
							</div>
						</article>
					))
				}
			</div>
			<button class="arrow arrow-next" aria-label="Scroll right">
				<Fragment set:html={icons["carousel-next"]} />
			</button>
		</div>
	</div>
</section>

<style>
	.team {
		background: var(--color-primary);
		padding: 5rem 5rem;
	}
	.container {
		max-width: 1280px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	/* ── Header ──────────────────────────────────────────── */
	.section-header {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 0.6rem;
	}
	.section-title {
		font-size: clamp(1.5rem, 3vw, var(--text-4xl));
		font-weight: var(--weight-bold);
		color: #fff;
		letter-spacing: var(--tracking-tight);
		margin: 0;
	}
	.section-body {
		font-size: var(--text-base);
		color: rgba(255, 255, 255, 0.65);
		margin: 0;
	}

	/* ── Carousel ────────────────────────────────────────── */
	.carousel-wrap {
		display: flex;
		align-items: center;
		gap: 1rem;
	}
	.track {
		flex: 1;
		display: flex;
		gap: 1.25rem;
		overflow-x: auto;
		scroll-snap-type: x mandatory;
		-webkit-overflow-scrolling: touch;
		padding-bottom: 0.25rem;
		scrollbar-width: none;
	}
	.track::-webkit-scrollbar {
		display: none;
	}

	/* ── Arrow buttons ───────────────────────────────────── */
	.arrow {
		flex-shrink: 0;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 50%;
		border: 1.5px solid rgba(255, 255, 255, 0.2);
		background: rgba(255, 255, 255, 0.08);
		color: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		transition: background 0.18s, border-color 0.18s;
	}
	.arrow:hover {
		background: var(--color-accent);
		border-color: var(--color-accent);
	}
	.arrow:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 3px;
	}
	.arrow:disabled {
		opacity: 0.25;
		cursor: default;
		pointer-events: none;
	}

	/* ── Card ────────────────────────────────────────────── */
	.card {
		flex: 0 0 270px;
		scroll-snap-align: start;
		background: #fff;
		border-radius: 1.25rem;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		box-shadow: 0 4px 24px rgba(0, 0, 0, 0.18);
		transition: transform 0.2s, box-shadow 0.2s;
	}
	.card:hover {
		transform: translateY(-4px);
		box-shadow: 0 12px 40px rgba(0, 0, 0, 0.25);
	}
	.photo-wrap {
		width: 5.5rem;
		height: 5.5rem;
		border-radius: 50%;
		overflow: hidden;
		flex-shrink: 0;
		margin: 1.75rem auto 0;
		border: 3px solid rgba(0, 193, 253, 0.2);
		box-shadow: 0 2px 12px rgba(0, 50, 125, 0.12);
		background: rgba(0, 193, 253, 0.1);
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.initials {
		font-size: var(--text-xl);
		font-weight: var(--weight-bold);
		color: var(--color-accent);
		letter-spacing: 0.02em;
	}
	.photo {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.card-body {
		padding: 1rem 1.5rem 1.5rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 0.3rem;
		flex: 1;
	}
	.member-role {
		font-size: var(--text-xs);
		font-family: var(--font-nav);
		font-weight: var(--weight-semibold);
		letter-spacing: 0.07em;
		text-transform: uppercase;
		color: var(--color-accent);
		margin: 0 0 0.25rem;
		min-height: 2.5rem;
		display: flex;
		align-items: flex-end;
		justify-content: center;
	}
	.member-name {
		font-size: var(--text-base);
		font-weight: var(--weight-bold);
		color: var(--color-primary);
		margin: 0 0 0.5rem;
		line-height: var(--leading-tight);
	}
	.member-bio {
		font-size: var(--text-sm);
		color: var(--color-text-body);
		line-height: var(--leading-loose);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 4;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.member-bio.expanded {
		display: block;
		-webkit-line-clamp: unset;
		overflow: visible;
	}
	.read-more {
		background: none;
		border: none;
		padding: 0;
		margin-top: 0.4rem;
		font-size: var(--text-xs);
		font-family: var(--font-nav);
		font-weight: var(--weight-semibold);
		color: var(--color-accent);
		cursor: pointer;
		letter-spacing: 0.03em;
		text-align: center;
		width: fit-content;
	}
	.read-more:hover {
		text-decoration: underline;
	}
	.read-more:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
		border-radius: 2px;
	}

	/* ── Responsive ──────────────────────────────────────── */
	@media (max-width: 900px) {
		.team {
			padding: 4rem 3rem;
		}
	}
	@media (max-width: 640px) {
		.team {
			padding: 3.5rem 1.25rem;
		}
		.card {
			flex: 0 0 calc(80vw - 2.5rem);
			max-width: 280px;
		}
		.arrow {
			display: none;
		}
		.carousel-wrap {
			gap: 0;
		}
	}
</style>

<script>
	import { animate, inView, stagger } from "motion";

	document.addEventListener("astro:page-load", () => {
		const track = document.querySelector(".team .track") as HTMLElement | null;
		const prevBtn = document.querySelector(".team .arrow-prev") as HTMLButtonElement | null;
		const nextBtn = document.querySelector(".team .arrow-next") as HTMLButtonElement | null;

		if (track) {
			const cards = [...track.children];
			for (let i = cards.length - 1; i > 0; i--) {
				const j = Math.floor(Math.random() * (i + 1));
				[cards[i], cards[j]] = [cards[j], cards[i]];
			}
			cards.forEach((card) => track.appendChild(card));
			track.scrollLeft = 0;
		}

		document.querySelectorAll<HTMLButtonElement>(".team .read-more").forEach((btn) => {
			const bio = btn.previousElementSibling as HTMLElement;
			btn.addEventListener("click", () => {
				const expanded = bio.classList.toggle("expanded");
				btn.textContent = expanded ? "Read less" : "Read more";
				btn.setAttribute("aria-expanded", String(expanded));
			});
		});

		if (track && prevBtn && nextBtn) {
			const SCROLL_AMOUNT = 295;

			const updateArrows = () => {
				prevBtn.disabled = track.scrollLeft <= 0;
				nextBtn.disabled = track.scrollLeft + track.clientWidth >= track.scrollWidth - 1;
			};

			prevBtn.addEventListener("click", () => {
				track.scrollBy({ left: -SCROLL_AMOUNT, behavior: "smooth" });
			});
			nextBtn.addEventListener("click", () => {
				track.scrollBy({ left: SCROLL_AMOUNT, behavior: "smooth" });
			});

			track.addEventListener("scroll", updateArrows, { passive: true });
			updateArrows();
		}

		if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
			inView(".team", () => {
				(animate as any)(
					".team .section-title, .team .section-body",
					{ opacity: [0, 1], y: [16, 0] },
					{ duration: 0.5, easing: [0.22, 1, 0.36, 1] },
				);
				(animate as any)(
					".team .card",
					{ opacity: [0, 1], y: [32, 0] },
					{ duration: 0.5, delay: stagger(0.08), easing: [0.22, 1, 0.36, 1] },
				);
			});
		}
	});
</script>
